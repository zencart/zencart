{
    "name": "zencart/zencart",
    "description": "Open Source E-commerce Application",
    "homepage": "https://www.zen-cart.com",
    "license": "GPL-2.0-only",
    "authors": [
        {
            "name": "The Zen-Cart Team",
            "homepage": "https://github.com/zencart/zencart/graphs/contributors"
        }
    ],
    "funding": [
        {
            "type": "other",
            "url": "https://zen-cart.com/donate"
        }
    ],
    "support": {
        "forum": "https://zen-cart.com/forum",
        "source": "https://zen-cart.com/getit",
        "docs": "https://docs.zen-cart.com"
    },
    "_comment": "compatible with PHP 8.3-8.5",
    "require": {
        "php": "^8.3",
        "ext-curl": "*",
        "ext-ctype": "*",
        "ext-fileinfo": "*",
        "ext-filter": "*",
        "ext-gd": "*",
        "ext-hash": "*",
        "ext-iconv": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-pcre": "*"
    },
    "require-dev": {
        "ext-pdo": "*",
        "guzzlehttp/guzzle": "^7.7",
        "mikey179/vfsstream": "^1.6",
        "phpunit/phpunit": "^11.5.42",
        "symfony/css-selector": "^6.0",
        "symfony/dom-crawler": "^7.4",
        "symfony/maker-bundle": "^1.49",
        "symfony/mime": "^6.0",
        "symfony/phpunit-bridge": "^7.0"
    },
    "autoload": {
        "classmap": ["includes/classes", "includes/modules"]
    },
    "include-path": ["includes/"],
    "autoload-dev": {
        "classmap": ["not_for_release/testFramework"],
        "psr-4": {
            "Tests\\": "not_for_release/testFramework/",
            "Seeders\\": "not_for_release/testFramework/Support/database/Seeders/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "3.0.x-dev"
        }
    },
    "config": {
        "bin-dir": "vendor/bin",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "tests-ci": "bash not_for_release/testFramework/run-tests-ci.sh",
        "tests-ci-local": "bash not_for_release/testFramework/run-tests-ci-local.sh",
        "tests-db-prepare-workers": "bash not_for_release/testFramework/prepare-worker-databases.sh",
        "tests-feature": "bash not_for_release/testFramework/run-feature-tests-ci.sh",
        "tests-feature-admin": "bash not_for_release/testFramework/run-admin-feature-tests-ci.sh",
        "tests-feature-admin-parallel": "bash not_for_release/testFramework/run-parallel-admin-feature-tests.sh",
        "tests-feature-admin-plugin-filesystem": "phpunit --testsuite FeatureAdmin --group plugin-filesystem",
        "tests-feature-local": "bash not_for_release/testFramework/run-feature-tests-ci-local.sh",
        "tests-feature-parallel": "bash not_for_release/testFramework/run-parallel-feature-tests.sh",
        "tests-feature-store": "bash not_for_release/testFramework/run-store-feature-tests-ci.sh",
        "tests-feature-store-parallel": "bash not_for_release/testFramework/run-parallel-storefront-feature-tests.sh",
        "tests-plugin": "bash not_for_release/testFramework/run-plugin-tests.sh",
        "tests-report-feature-groups": "bash not_for_release/testFramework/report-feature-test-groups.sh",
        "tests-report-feature-groups-strict": "bash not_for_release/testFramework/report-feature-test-groups.sh --fail-on-untagged --summary-only",
        "tests-runtime-describe": "php not_for_release/testFramework/describe-worker-runtime.php",
        "tests-unit": "bash not_for_release/testFramework/run-parallel-unit-tests.sh"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
